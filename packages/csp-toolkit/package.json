{
    "name": "csp-toolkit",
    "version": "1.4.0",
    "author": {
        "name": "Tsotne Gvadzabia"
    },
    "description": "A comprehensive toolkit for working with Content Security Policy (CSP) directives in TypeScript.",
    "scripts": {
        "build": "tsup",
        "test": "vitest"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/tsotimus/csp-toolkit",
        "directory": "packages/csp-toolkit"
    },
    "homepage": "https://vite-csp.tsotne.co.uk",
    "license": "MIT",
    "exports": {
        ".": {
            "types": "./dist/types/index.d.ts",
            "import": "./dist/index.esm.js",
            "require": "./dist/index.cjs.js"
        },
        "./node": {
            "types": "./dist/node/types/node.d.ts",
            "import": "./dist/node/node.esm.js",
            "require": "./dist/node/node.cjs.js"
        },
        "./edge": {
            "types": "./dist/edge/types/edge.d.ts",
            "import": "./dist/edge/edge.esm.js",
            "require": "./dist/edge/edge.cjs.js"
        }
    },
    "type": "module",
    "types": "dist/types/index.d.ts",
    "typings": "dist/types/index.d.ts",
    "main": "dist/index.cjs.js",
    "module": "dist/index.esm.js",
    "devDependencies": {
        "@repo/eslint-config": "workspace:^",
        "@repo/typescript-config": "workspace:^",
        "@types/node": "^20.14.2",
        "tsup": "^8.3.5",
        "typescript": "^5.8.2",
        "vitest": "^1.6.0"
    },
    "files": [
        "dist",
        "LICENSE"
    ],
    "keywords": [
        "csp",
        "security",
        "content-security-policy",
        "types",
        "toolkit"
    ]
}
